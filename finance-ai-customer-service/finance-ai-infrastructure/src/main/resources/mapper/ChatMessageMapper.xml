<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- 对话消息 Mapper XML 映射 -->
<mapper namespace="com.company.finance.infrastructure.mapper.ChatMessageMapper">

    <!-- 结果映射：数据库列名（下划线）→ Java 字段名（驼峰） -->
    <resultMap id="chatMessageResultMap" type="com.company.finance.domain.entity.ChatMessage">
        <id property="messageId" column="message_id"/>
        <result property="sessionId" column="session_id"/>
        <result property="role" column="role"/>
        <result property="content" column="content"/>
        <result property="intent" column="intent"/>
        <result property="timestamp" column="timestamp"/>
        <!-- metadata_json 以 String 形式映射，上层服务负责反序列化为 Map -->
    </resultMap>

    <!-- 插入对话消息 -->
    <insert id="insert">
        INSERT INTO t_chat_message (message_id, session_id, role, content, intent, metadata_json, timestamp)
        VALUES (#{message.messageId}, #{message.sessionId}, #{message.role},
                #{message.content}, #{message.intent}, #{metadataJson}, #{message.timestamp})
    </insert>

    <!-- 根据会话 ID 查询消息列表（按时间戳升序） -->
    <select id="selectBySessionId" resultMap="chatMessageResultMap">
        SELECT message_id, session_id, role, content, intent, metadata_json, timestamp
        FROM t_chat_message
        WHERE session_id = #{sessionId}
        ORDER BY timestamp ASC
    </select>

</mapper>
